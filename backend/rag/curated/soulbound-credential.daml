-- =============================================================
-- Curated reference pattern: Soulbound credential / non-transferable badge
-- =============================================================
-- A digital certificate / badge / membership / credential bound to
-- the recipient FOREVER. The "soulbound" property is enforced
-- declaratively by the ABSENCE of a Transfer choice \xe2\x80\x94 there is no
-- need for ERC721 `_beforeTokenTransfer` overrides; in Daml, what
-- you don't write doesn't exist.
--
-- Key idioms demonstrated:
--   * NO `Transfer` / `ChangeOwner` / `Reassign` choice. EVER.
--   * NO `amount : Decimal` field \xe2\x80\x94 credentials carry text + time,
--     not money. Avoid the LLM bait of always putting an amount.
--   * Issuer-only `Revoke` (the legitimate way to remove a credential).
--   * Recipient-only `Verify` (non-archiving, returns badge details).
--   * Descriptive `assertMsg` instead of cryptic `ensure` failures.
--   * `metadataUri : Optional Text` for off-chain JSON / IPFS.
-- =============================================================

module Main where

template Credential
  with
    issuer       : Party
    recipient    : Party
    badgeName    : Text
    description  : Text
    issuedAt     : Time
    metadataUri  : Optional Text
  where
    signatory issuer
    observer recipient

    ensure issuer /= recipient && badgeName /= ""

    -- Recipient-side read: returns badge details without archiving.
    -- `nonconsuming` is critical \xe2\x80\x94 verifying must not destroy the credential.
    nonconsuming choice Verify : Text
      controller recipient
      do
        return (badgeName <> " \xe2\x80\x94 " <> description)

    -- Issuer-only revocation. There is intentionally NO Transfer
    -- choice \xe2\x80\x94 omission IS the soulbound enforcement mechanism.
    choice Revoke : ()
      with
        reason : Text
      controller issuer
      do
        assertMsg "Reason for revocation must be provided" (reason /= "")
        return ()
