# Ginie Backend — environment configuration
# Copy to .env.ginie and fill in your values:
#   cp .env.ginie.example .env.ginie

# --- LLM Provider (choose one) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/ginie_daml

# Canton sandbox storage
CANTON_DB_HOST=localhost
CANTON_DB_PORT=5432
CANTON_DB_NAME=canton_sandbox
CANTON_DB_USER=postgres
CANTON_DB_PASSWORD=password

# --- Canton Network ---
CANTON_ENVIRONMENT=sandbox          # sandbox | devnet | mainnet
CANTON_SANDBOX_URL=http://localhost:7575
CANTON_TOKEN=

# DevNet / MainNet (leave blank for sandbox)
CANTON_DEVNET_URL=
CANTON_MAINNET_URL=

# OAuth2 (DevNet only)
CANTON_OAUTH2_TOKEN_URL=
CANTON_CLIENT_ID=
CANTON_CLIENT_SECRET=
CANTON_SCOPE=
CANTON_AUDIENCE=

# API version: auto = sandbox→v1, devnet/mainnet→v2
CANTON_API_VERSION=auto

# --- Daml SDK ---
DAML_SDK_VERSION=2.10.4

# --- Async (optional — falls back to BackgroundTasks without Redis) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=                         # REQUIRED for non-sandbox environments
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
